# Backend-only environment variables for AI Kids Buddy
# Do not set these in frontend code; keys are sensitive.

# Primary API key for MIMO (required)
MIMO_TOKEN_PLAN_KEY=your-mimo-token-plan-key

# Fallback API key for MIMO (optional)
MIMO_API_KEY=your-mimo-api-key

# MIMO API base URL (optional, default: https://api.mimo.ai/v1)
MIMO_BASE_URL=https://api.mimo.ai/v1

# MIMO API endpoint (optional, overrides base URL + /chat/completions)
MIMO_ENDPOINT=https://api.mimo.ai/v1/chat/completions

# MIMO model name (optional, default: mimo-default)
MIMO_MODEL=mimo-default